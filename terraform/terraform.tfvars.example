# Copy to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it contains the secret_key.

aws_region = "eu-west-2"
app_name   = "meat-ensemble"

# t4g.nano  = ~$3/mo  (512 MB RAM — workable but tight)
# t4g.micro = ~$6/mo  (1 GB RAM — recommended)
# t4g.small = ~$12/mo (2 GB RAM — if you add more users)
instance_type = "t4g.micro"

# Your domain and the Route53 zone it lives in
domain_name     = "themeatensemble.uk"
route53_zone_id = "Z07471842KTHH201RTW88"
www_record      = false

# Git repo containing this project
repo_url = "https://github.com/gr4y-r0se/mutual_mastication.git"

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
secret_key = "KJSXHD789EWQ747893BNC423T684CB23789BC46238C46C2876C48235BC4823B5"

# Used for Let's Encrypt registration
certbot_email = "liam@gr4y-r0se.com"

# SES sender address — must use a domain that SES has verified (themeatensemble.uk).
# After terraform apply, check verification status with the ses_verify_cmd output,
# then request SES production access to send to unverified addresses.
ses_from_address = "noreply@themeatensemble.uk"

# SSH access — leave key_name as null to use SSM Session Manager instead (recommended)
# key_name          = "your-keypair-name"
# ssh_allowed_cidrs = ["YOUR_HOME_IP/32"]
